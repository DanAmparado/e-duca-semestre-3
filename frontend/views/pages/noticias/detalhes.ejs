<%- include('../../partials/head') %>
<%- include('../../partials/navbar') %>
<div class="container mt-4">
    <h1><%= noticia.titulo %></h1>
    <p class="text-muted">Publicado em: <%= noticia.data_publicacao.toLocaleDateString() %></p>
    <% if (noticia.etapa_educacional) { %>
        <span class="badge bg-info">Etapa: <%= noticia.etapa_educacional %></span>
    <% } %>
    <hr>
    <div class="noticia-conteudo">
        <%= noticia.conteudo.replace(/\n/g, '<br>') %>
    </div>
    <a href="/noticias" class="btn btn-secondary mt-3">← Voltar</a>
</div>
<%- include('../../partials/footer') %>