<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <%- include('../../partials/head', { title: 'Editar Notícia - E-DUCA' }) %>
</head>
<body>
    <div class="d-flex">
        <%- include('../partials/admin-sidebar', { currentPage: 'noticias' }) %>
        
        <div class="container-fluid">
            <h1 class="h3 mb-4">Editar Notícia</h1>

            <div class="card shadow">
                <div class="card-body">
                    <form action="/admin/noticias/editar/<%= noticia.id %>" method="POST">
                        <div class="mb-3">
                            <label for="titulo" class="form-label">Título *</label>
                            <input type="text" class="form-control" id="titulo" name="titulo" required value="<%= noticia.titulo %>">
                        </div>
                        <div class="mb-3">
                            <label for="conteudo" class="form-label">Conteúdo *</label>
                            <textarea class="form-control" id="conteudo" name="conteudo" rows="10" required><%= noticia.conteudo %></textarea>
                        </div>
                        <div class="mb-3">
                            <label for="status" class="form-label">Status</label>
                            <select class="form-control" id="status" name="status">
                                <option value="rascunho" <%= noticia.status === 'rascunho' ? 'selected' : '' %>>Rascunho</option>
                                <option value="agendado" <%= noticia.status === 'agendado' ? 'selected' : '' %>>Agendado</option>
                                <option value="publicado" <%= noticia.status === 'publicado' ? 'selected' : '' %>>Publicado</option>
                                <option value="arquivado" <%= noticia.status === 'arquivado' ? 'selected' : '' %>>Arquivado</option>
                            </select>
                        </div>
                        <div class="mb-3">
                            <label for="data_agendamento" class="form-label">Data de Agendamento</label>
                            <input type="datetime-local" class="form-control" id="data_agendamento" name="data_agendamento" value="<%= noticia.data_agendamento ? new Date(noticia.data_agendamento).toISOString().slice(0,16) : '' %>">
                        </div>
                        <div class="mb-3">
                            <label for="etapa_educacional" class="form-label">Etapa Educacional</label>
                            <select class="form-control" id="etapa_educacional" name="etapa_educacional">
                                <option value="">Selecione...</option>
                                <option value="Educação Básica" <%= noticia.etapa_educacional === 'Educação Básica' ? 'selected' : '' %>>Educação Básica</option>
                                <option value="Ensino Fundamental" <%= noticia.etapa_educacional === 'Ensino Fundamental' ? 'selected' : '' %>>Ensino Fundamental</option>
                                <option value="Ensino Médio" <%= noticia.etapa_educacional === 'Ensino Médio' ? 'selected' : '' %>>Ensino Médio</option>
                                <option value="Educação Técnica" <%= noticia.etapa_educacional === 'Educação Técnica' ? 'selected' : '' %>>Educação Técnica</option>
                                <option value="Educação Superior" <%= noticia.etapa_educacional === 'Educação Superior' ? 'selected' : '' %>>Educação Superior</option>
                            </select>
                        </div>
                        <button type="submit" class="btn btn-primary">Atualizar</button>
                        <a href="/admin/noticias" class="btn btn-secondary">Cancelar</a>
                    </form>
                </div>
            </div>
        </div>
    </div>
    <%- include('../../partials/footer') %>
</body>
</html>