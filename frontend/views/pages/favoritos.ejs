<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <%- include('../partials/head', { title: 'Meus Favoritos - E-DUCA' }) %>
</head>
<body>
    <%- include('../partials/navbar', { user: user }) %>

    <div class="container mt-4">
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb">
                <li class="breadcrumb-item"><a href="/">Início</a></li>
                <li class="breadcrumb-item active">Meus Favoritos</li>
            </ol>
        </nav>

        <div class="row">
            <div class="col-12">
                <h1 class="mb-4">
                    <i class="bi bi-heart-fill text-danger"></i> Meus Favoritos
                </h1>

                <% if (favoritos.length === 0) { %>
                    <div class="alert alert-info">
                        <i class="bi bi-info-circle"></i> Você ainda não adicionou nenhum recurso aos favoritos.
                        <br><br>
                        <a href="/recursos" class="btn btn-primary">Explorar recursos</a>
                    </div>
                <% } else { %>
                    <div class="row">
                        <% favoritos.forEach(recurso => { %>
                        <div class="col-md-6 col-lg-4 mb-4">
                            <div class="card h-100 shadow-sm">
                                <div class="card-body">
                                    <h5 class="card-title">
                                        <%= recurso.titulo.length > 60 ? 
                                            recurso.titulo.substring(0, 60) + '...' : 
                                            recurso.titulo %>
                                    </h5>
                                    <p class="card-text text-muted small">
                                        <%= recurso.descricao && recurso.descricao.length > 120 ? 
                                            recurso.descricao.substring(0, 120) + '...' : 
                                            (recurso.descricao || 'Descrição não disponível.') %>
                                    </p>
                                    <div class="mb-2">
                                        <span class="badge bg-primary">
                                            <%= recurso.etapa %>
                                        </span>
                                    </div>
                                </div>
                                <div class="card-footer bg-transparent">
                                    <div class="d-flex justify-content-between align-items-center">
                                        <div>
                                            <a href="<%= recurso.link_externo %>" 
                                               target="_blank" 
                                               class="btn btn-primary btn-sm">
                                                <i class="bi bi-globe"></i> Acessar
                                            </a>
                                            <a href="/recursos/<%= recurso.id %>" 
                                               class="btn btn-outline-secondary btn-sm">
                                                <i class="bi bi-info-circle"></i> Detalhes
                                            </a>
                                        </div>
                                        <button class="btn btn-sm btn-danger remover-fav" 
                                                data-id="<%= recurso.id %>">
                                            <i class="bi bi-trash"></i> Remover
                                        </button>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <% }) %>
                    </div>
                <% } %>
            </div>
        </div>
    </div>

    <%- include('../partials/footer') %>

    <script>
        document.querySelectorAll('.remover-fav').forEach(btn => {
            btn.addEventListener('click', async function() {
                const id = this.dataset.id;
                if (!confirm('Remover este recurso dos favoritos?')) return;
                try {
                    const response = await fetch(`/favoritos/${id}/remover`, { method: 'DELETE' });
                    if (response.ok) {
                        // Remove o card da página
                        this.closest('.col-md-6.col-lg-4.mb-4').remove();
                        // Se não houver mais favoritos, recarrega para mostrar a mensagem
                        if (document.querySelectorAll('.remover-fav').length === 1) {
                            location.reload();
                        }
                    } else {
                        const data = await response.json();
                        alert(data.error || 'Erro ao remover');
                    }
                } catch (err) {
                    console.error(err);
                    alert('Erro de conexão');
                }
            });
        });
    </script>
</body>
</html>