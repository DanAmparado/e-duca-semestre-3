<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <%- include('../../partials/head', { title: 'Gerenciar Notícias - E-DUCA' }) %>
</head>
<body>
    <div class="d-flex">
        <%- include('../partials/admin-sidebar', { currentPage: 'noticias' }) %>
        
        <div class="main-content p-4">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h1 class="h3">Gerenciar Notícias</h1>
                <a href="/admin/noticias/criar" class="btn btn-success">Nova Notícia</a>
            </div>

            <% if (success && success.length) { %>
                <div class="alert alert-success alert-dismissible fade show" role="alert">
                    <%= success %>
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            <% } %>
            <% if (error && error.length) { %>
                <div class="alert alert-danger alert-dismissible fade show" role="alert">
                    <%= error %>
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            <% } %>

            <div class="card shadow">
                <div class="card-body">
                    <div class="table-responsive">
                        <table class="table table-striped">
                            <thead>
                                <tr><th>ID</th><th>Título</th><th>Status</th><th>Publicação</th><th>Ações</th></tr>
                            </thead>
                            <tbody>
                                <% noticias.forEach(noticia => { %>
                                <tr>
                                    <td><%= noticia.id %></td>
                                    <td><%= noticia.titulo %></td>
                                    <td><span class="badge bg-secondary"><%= noticia.status %></span></td>
                                    <td><%= noticia.data_publicacao ? noticia.data_publicacao.toLocaleDateString('pt-BR') : '-' %></td>
                                    <td>
                                        <a href="/admin/noticias/editar/<%= noticia.id %>" class="btn btn-sm btn-primary">Editar</a>
                                        <% if (noticia.status !== 'publicado') { %>
                                            <form action="/admin/noticias/<%= noticia.id %>/publicar" method="POST" style="display:inline;">
                                                <button class="btn btn-sm btn-success">Publicar</button>
                                            </form>
                                        <% } %>
                                        <% if (noticia.status !== 'arquivado') { %>
                                            <form action="/admin/noticias/<%= noticia.id %>/arquivar" method="POST" style="display:inline;">
                                                <button class="btn btn-sm btn-warning">Arquivar</button>
                                            </form>
                                        <% } %>
                                        <form action="/admin/noticias/excluir/<%= noticia.id %>" method="POST" style="display:inline;" onsubmit="return confirm('Excluir permanentemente?')">
                                            <button class="btn btn-sm btn-danger">Excluir</button>
                                        </form>
                                    </td>
                                </tr>
                                <% }) %>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <%- include('../../partials/footer') %>
</body>
</html>